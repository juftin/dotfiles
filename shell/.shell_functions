##########################################################
######################### SEARCH #########################
##########################################################

# search for a file
function f() {
	find . -iname "*$1*" ${@:2}
}

# search for a string in files
function r() {
	grep "$1" ${@:2} -R .
}

##########################################################
###################### DIRECTORIES #######################
##########################################################

# Create a folder and move into it in one command
function mkcd() {
	mkdir -p "$@" && cd "$_"
}

# create a tmp directory
function mktmpdir() {
  test -z "$TMPDIR" && TMPDIR="$(mktemp -d)"
  mkdir -p "${TMPDIR}"
  echo "${TMPDIR}"
}

##########################################################
########################## GIT ###########################
##########################################################

# check out a branch
function check() {
	git checkout $1
}

# remove local versions of deleted remote branches
function git-remove-deleted() {
	git fetch -p
	for branch in $(git branch -vv | grep ': gone]' | awk '{print $1}'); do
		git branch -D $branch
	done
}

# tree with gitignore
function git-tree() {
    tree -C -I $((cat .gitignore 2> /dev/null || cat $(git rev-parse --show-toplevel 2> /dev/null)/.gitignore 2> /dev/null || echo "node_modules") | egrep -v "^#.*$|^[[:space:]]*$" | tr "\\n" "|" | rev | cut -c 2- | rev)
}

